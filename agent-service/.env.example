# ─── Agent Service environment template ───────────────────────────────
# Copy to .env.local and fill in real values. .env.local is gitignored.

# Server
NODE_ENV=local
PORT=3020

# LLM (OpenAI) — required
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# MongoDB Atlas — required (new loc_prag_agent database)
MONGODB_URI=mongodb+srv://agent:<password>@loc-prag-agent.xxxxx.mongodb.net/loc_prag_agent?retryWrites=true&w=majority

# Redis (rate-limit / cache) — optional in dev
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Agent tuning
AGENT_MAX_STEPS=8
AGENT_MAX_LISTINGS=40
AGENT_TOP_N_DRAFTS=3
